# ---- Broker (Alpaca) ----
# Get keys at https://alpaca.markets — paper first, live later (post 30-day qualifier).
BROKER_PROVIDER=paper          # one of: paper | alpaca | backtest
PAPER_MODE=true                # when BROKER_PROVIDER=alpaca, keep true until go-live gate passed
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ---- Database (local: Docker Compose; prod: native Postgres) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quant
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant_dev_pw
DATABASE_URL=postgresql+psycopg://quant:quant_dev_pw@localhost:5432/quant

# ---- Discord alerting ----
DISCORD_WEBHOOK_URL=
DISCORD_KILLSWITCH_BOT_TOKEN=

# ---- Sentry ----
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev         # dev | paper | live

# ---- Runtime ----
QUANT_ENV=dev                  # dev | paper | live
QUANT_LOG_LEVEL=INFO
QUANT_DATA_DIR=./data
QUANT_KILLSWITCH_FILE=/var/run/quant/HALT
QUANT_CONFIG_DIR=./config

# ---- Observability (optional in dev) ----
PROMETHEUS_PORT=9000
